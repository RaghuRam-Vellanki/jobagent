# FastAPI server
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# Auth — CHANGE THIS in production! Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=7152bfd03c5e9022ea8ea60ff4b41a83c34f84088207ee1b5933acbfe5387117

# Email notifications (E5-S5). Optional — fill in to enable per-apply emails.
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_USE_SSL=true.
# SMTP_USER must be the gmail address; SMTP_PASSWORD must be an App Password
# (https://myaccount.google.com/apppasswords) — your normal Gmail password
# will not work for SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
